				},
				{
					"name": "Anomalías",
					"request": { "method": "GET", "url": { "raw": "http://localhost:8108/api/analitica/reportes/anomalias", "host": ["http://localhost"], "port": "8108", "path": ["api", "analitica", "reportes", "anomalias"] } }
				}
			]
		},
		{
			"name": "Notificaciones",
			"item": [
				{
					"name": "Listar Notificaciones",
					"request": { "method": "GET", "url": { "raw": "http://localhost:8108/api/notificaciones/notificaciones", "host": ["http://localhost"], "port": "8108", "path": ["api", "notificaciones", "notificaciones"] } }
				}
			]
		}
	]
